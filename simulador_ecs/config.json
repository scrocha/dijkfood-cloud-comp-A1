      "DESCRIPTION": "Simulador de Entregadores",
      "ENV_MAPPING": {
        "GENERAL_API_URL": "{SIM_ALB_URL}"
      },
      "DESIRED_COUNT": 1,
      "DEFAULT_CMD": null
