# -----------------------------------------------------------------------------
# Backend da UI: docker (local + proxy Vite) ou aws (URLs absolutas)
# Copie para .env e ajuste. Reinicie `npm run dev` após mudar.
# -----------------------------------------------------------------------------

# Local: mesmo host que o Vite; /cadastro, /rotas, /pedidos → proxy → 8002–8004
# VITE_BACKEND_TARGET=docker

# Remoto (ALB, domínio único com path routing, etc.): preencha as três origens (sem / no fim)
VITE_BACKEND_TARGET=aws
VITE_CADASTRO_URL= http://dijkfood-alb-1175042617.us-east-1.elb.amazonaws.com
VITE_ROTAS_URL= http://dijkfood-alb-1175042617.us-east-1.elb.amazonaws.com
VITE_PEDIDOS_URL= http://dijkfood-alb-1175042617.us-east-1.elb.amazonaws.com
